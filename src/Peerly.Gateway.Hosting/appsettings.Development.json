{
  "Auth": {
    "Issuer": "peerly-auth",
    "Audience": "peerly-gateway",
    "AuthGrpcAddress": "http://localhost:5002",
    "RoleClaimType": "roles"
  },
  "Cookies": {
    "AccessName": "access",
    "RefreshName": "refresh",
    "CsrfName": "csrf",
    "Secure": true,
    "SameSite": "Lax",
    "RefreshPath": "/auth/refresh"
  },
  "Cors": {
    "AllowedOrigins": ["https://app.peerly.com"]
  }
}
